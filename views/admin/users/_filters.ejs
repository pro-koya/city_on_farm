<div class="lv__filter">
  <label class="lv__label" for="fRole">ロール</label>
  <select class="lv__select pulldown" id="fRole" name="role">
    <option value="">すべて</option>
    <option value="admin"  <%= roleVal==='admin' ?'selected':'' %>>管理者</option>
    <option value="seller" <%= roleVal==='seller'?'selected':'' %>>出品者</option>
    <option value="buyer"  <%= roleVal==='buyer' ?'selected':'' %>>購入者</option>
  </select>
</div>

<div class="lv__filter">
  <label class="lv__label" for="fStatus">状態</label>
  <select class="lv__select pulldown" id="fStatus" name="status">
    <option value="">すべて</option>
    <option value="active" <%= statusVal==='active'?'selected':'' %>>有効</option>
    <option value="locked" <%= statusVal==='locked'?'selected':'' %>>ロック中</option>
  </select>
</div>

<div class="lv__filter">
  <label class="lv__label" for="fSort">並び順</label>
  <select class="lv__select pulldown" id="fSort" name="sort">
    <option value="recent"    <%= sortVal==='recent'   ?'selected':'' %>>新しい順</option>
    <option value="name_asc"  <%= sortVal==='name_asc' ?'selected':'' %>>名前(昇順)</option>
    <option value="name_desc" <%= sortVal==='name_desc'?'selected':'' %>>名前(降順)</option>
    <option value="updated"   <%= sortVal==='updated'  ?'selected':'' %>>更新が新しい順</option>
  </select>
</div>
