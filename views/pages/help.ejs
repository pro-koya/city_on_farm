    <!-- お問い合わせ -->
    <section class="help-contact">
      <h2>解決しない場合は</h2>
      <p>このガイドで解決しない場合は、お気軽にお問い合わせください。</p>
      <a href="/contact" class="help-contact__btn">お問い合わせフォームへ</a>
    </section>

  </div>
</main>

<script>
// アコーディオン機能
document.querySelectorAll('[data-accordion]').forEach(accordion => {
  const trigger = accordion.querySelector('.help-accordion__trigger');
  const content = accordion.querySelector('.help-accordion__content');

  trigger.addEventListener('click', () => {
    const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
    trigger.setAttribute('aria-expanded', !isExpanded);
    accordion.classList.toggle('is-open', !isExpanded);
  });
});

// URLハッシュがある場合、該当セクションまでスクロール
if (window.location.hash) {
  const target = document.querySelector(window.location.hash);
  if (target) {
    setTimeout(() => {
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 100);
  }
}
</script>

