<%- include('../partials/header', { title: 'ログイン', extraCSS2: '',
  extraCSS: '/styles/auth.css' }) %>

<main class="auth">
  <section class="auth-card" role="region" aria-labelledby="loginTitle">
    <div class="auth-card__header">
      <h1 id="loginTitle">おかえりなさい</h1>
      <p class="lead">メールアドレスとパスワードでログインしてください。</p>
    </div>

    <form id="loginForm" class="auth-form" method="POST" action="/login" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <!-- メールアドレス -->
      <div class="field">
        <label class="label" for="email">メールアドレス</label>
        <input class="input" id="email" name="email" type="email"
               value="<%= (values && values.email) || '' %>"
               placeholder="you@example.com"
               autocomplete="username" inputmode="email"
               aria-invalid="<%= fieldErrors && fieldErrors.email ? 'true' : 'false' %>"
               required>
        <p class="error" data-error-for="email"></p>
      </div>

      <!-- パスワード -->
      <div class="field">
        <div class="label-row">
          <label class="label" for="password">パスワード</label>
          <a class="link-small" href="/password/forgot">パスワードをお忘れですか？</a>
        </div>
        <div class="pwd">
          <input class="input" id="password" name="password" type="password"
                 placeholder="パスワードを入力"
                 autocomplete="current-password"
                 aria-invalid="<%= fieldErrors && fieldErrors.password ? 'true' : 'false' %>"
                 required>
          <button class="toggle" type="button" aria-label="パスワードを表示/非表示">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
        <p class="error" data-error-for="password"></p>
      </div>

      <!-- Remember Me -->
      <input id="remember" name="remember" type="hidden" value="1">

      <!-- サーバーエラー -->
      <% if (fieldErrors && fieldErrors.email) { %>
        <div class="global-error" role="alert"><%= fieldErrors.email %></div>
      <% } %>

      <!-- ログインボタン -->
      <button id="loginBtn" class="btn btn--primary btn--block" type="submit" disabled>ログイン</button>
    </form>

    <% if (showResendLink) { %>
      <form method="POST" action="/auth/verify/resend" class="resend-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn--outline btn--block">
          メールアドレスを認証する
        </button>
      </form>
    <% } %>

    <div class="auth-card__footer">
      <p>初めての方は <a href="/signup" class="link">新規アカウント作成</a></p>
    </div>
  </section>
</main>

<script src="/js/auth-login.js"></script>
<%- include('../partials/footer') %>