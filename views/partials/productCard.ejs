<div class="card" data-product-id="<%= p.id %>">
  <% 
    const productUrl = `/products/${p.id}`;
    const created = new Date(p.created_at);
    const today = new Date();

    created.setHours(0, 0, 0, 0);
    today.setHours(0, 0, 0, 0);

    const diffDays = (today - created) / (1000 * 60 * 60 * 24);
  %>

  <!-- お気に入りボタン ※カードリンクとは別要素にする -->
  <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <button type="button" 
            class="favorite-btn <%= (typeof p.isFavorited !== 'undefined' && p.isFavorited) ? 'is-favorited' : '' %>" 
            data-product-id="<%= p.id %>"
            aria-label="<%= (typeof p.isFavorited !== 'undefined' && p.isFavorited) ? 'お気に入りから削除' : 'お気に入りに追加' %>"
            aria-pressed="<%= (typeof p.isFavorited !== 'undefined' && p.isFavorited) ? 'true' : 'false' %>">
      <svg class="favorite-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
    </button>
  <% } else { %>
    <!-- 未ログイン時はログインへ誘導（ログイン後に戻れるよう next 付き） -->
    <a href="/login?next=<%= encodeURIComponent(productUrl) %>" 
       class="favorite-btn favorite-btn--guest" 
       aria-label="ログインしてからお気に入りに追加">
      <svg class="favorite-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
    </a>
  <% } %>

  <!-- カード全体のリンク（商品詳細へ） -->
  <a href="<%= productUrl %>" 
     class="card__link"
     data-product-id="<%= p.id %>" 
     aria-label="<%= p.title %>の詳細">

    <!-- 順位バッジ（ランキング表示時） -->
    <% if (typeof showRank !== 'undefined' && showRank && typeof rank !== 'undefined') { %>
      <span class="badge--rank badge--rank--<%= rank <= 3 ? rank : 'other' %>">
        <% if (rank === 1) { %>
          <svg class="badge--rank__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          <span>1位</span>
        <% } else if (rank === 2) { %>
          <svg class="badge--rank__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7.21 15 2.66 7.14a2 2 0 0 1 .13-2.2L4.4 2.8A2 2 0 0 1 6 2h12a2 2 0 0 1 1.6.8l1.6 2.14a2 2 0 0 1 .14 2.2L16.79 15"/><path d="M11 12 5.12 2.2"/><path d="m13 12 5.88-9.8"/><path d="M8 7h8"/><circle cx="12" cy="17" r="5"/><path d="M12 18v-2h-.5"/></svg>
          <span>2位</span>
        <% } else if (rank === 3) { %>
          <svg class="badge--rank__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          <span>3位</span>
        <% } else { %>
          <span><%= rank %>位</span>
        <% } %>
      </span>
    <% } %>

    <% if (diffDays <= 3 && diffDays >= 0) { %>
      <span class="badge--new">NEW</span>
    <% } %>
    
    <% if (p.stock === 0) { %>
      <span class="badge--low zero">在庫切れ</span>
    <% } else if (p.stock < 5) { %>
      <span class="badge--low">残り<%= p.stock %>点</span>
    <% } %>

    <img src="<%= p.image_url %>" alt="<%= p.title %>">
    <div class="card__body">
      <h3 class="card__name"><%= p.title %></h3>
      <% if (p.for_individual && p.for_corporate) { %>
        <span class="badge--audience badge--all">個人・法人向け</span>
      <% } else if (p.for_individual) { %>
        <span class="badge--audience badge--individual">個人向け</span>
      <% } else if (p.for_corporate) { %>
        <span class="badge--audience badge--corporate">法人向け</span>
      <% } %>
      <div class="card__meta">
        <span>¥<%= p.price %><%= p.has_variants ? '〜' : '' %></span>
        <span><%= p.unit || '' %></span>
      </div>

      <!-- 出品者名 -->
      <div class="card__seller">
        <% if (p.seller_partner_icon_url) { %>
          <!-- アイコン画像がある場合 -->
          <img class="card__seller-icon-img"
               src="<%= p.seller_partner_icon_url %>"
               alt="<%= p.seller_partner_name || p.seller_name %>のアイコン">
        <% } else { %>
          <!-- フォールバック：SVGアイコン -->
          <svg class="card__seller-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        <% } %>
        <span class="card__seller-name"><%= p.seller_partner_name || p.seller_name || '出品者不明' %></span>
      </div>

      <!-- ランキング情報（人気ランキング表示時） -->
      <% if (typeof showRank !== 'undefined' && showRank && p.quantity_sold != null) { %>
        <div class="card__stats" style="margin-top: 6px; font-size: 0.85rem; color: var(--muted);">
          <span>販売数: <%= p.quantity_sold || 0 %></span>
          <% if (p.order_count != null) { %>
            <span style="margin-left: 8px;">注文数: <%= p.order_count || 0 %>件</span>
          <% } %>
        </div>
      <% } %>

      <!-- お気に入り数（みんなのお気に入り表示時） -->
      <% if (typeof showFavoriteCount !== 'undefined' && showFavoriteCount && p.favorite_count != null && p.favorite_count > 0) { %>
        <div class="card__favorite-count" style="margin-top: 6px; font-size: 0.85rem; color: var(--muted); display: flex; align-items: center; gap: 4px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--danger)" stroke="var(--danger)" stroke-width="2" style="flex-shrink: 0;">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          <span><%= p.favorite_count %>人がお気に入り</span>
        </div>
      <% } %>
    </div>
  </a>
</div>